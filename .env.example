APP_NAME=XTTS Voice Cloning
APP_ENV=production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8001
GRADIO_PORT=7860

MODEL_CACHE_SIZE=2
AUDIO_SAMPLE_RATE=22050
STREAM_SAMPLE_RATE=16000
AUDIO_MAX_DURATION_SECONDS=600

TTS_BACKEND=coqui
USE_FP16=true
USE_ONNX=true
QUANTIZE=false
XTTS_REFERENCE_MAX_SECONDS=14
XTTS_REQUIRE_REFERENCE_VOICE=true
DEFAULT_SPEAKER_1_REFERENCE_AUDIO=
DEFAULT_SPEAKER_2_REFERENCE_AUDIO=
CUDA_VISIBLE_DEVICES=0
FFMPEG_PATH=ffmpeg

# Local Fish Speech backend. Start the Fish Speech server before generating.
FISH_SPEECH_URL=http://127.0.0.1:8080/v1/tts
FISH_SPEECH_API_KEY=
FISH_SPEECH_TEMPERATURE=0.25
FISH_SPEECH_TOP_P=0.55
FISH_SPEECH_REPETITION_PENALTY=1.25
FISH_SPEECH_CHUNK_LENGTH=300
FISH_SPEECH_SEED=42
FISH_SPEECH_FALLBACK_TO_XTTS=true
FISH_SPEECH_SPEAKER_1_REFERENCE_TEXT=मोदी एक शब्द नहीं बोल रहे
FISH_SPEECH_SPEAKER_2_REFERENCE_TEXT=
